<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp">

    <TextView
        android:id="@+id/tvOpponentInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Gegner: —"
        android:textSize="15sp"
        android:paddingBottom="4dp"/>

    <TextView
        android:id="@+id/tvDeckSize"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Deck: —"
        android:paddingBottom="4dp"/>

    <!-- Spielprotokoll, scrollbar -->
    <ScrollView
        android:id="@+id/scrollLog"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#11000000"
        android:padding="4dp">

        <TextView
            android:id="@+id/tvLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:fontFamily="monospace"/>
    </ScrollView>

    <TextView
        android:id="@+id/tvHand"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Hand: —"
        android:textSize="17sp"
        android:paddingTop="8dp"/>

    <TextView
        android:id="@+id/tvBooks"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Bücher: —"
        android:paddingBottom="8dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <EditText
            android:id="@+id/etRank"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Rang (2–10, J, Q, K, A)"
            android:inputType="textCapCharacters"
            android:maxLength="2"/>

        <Button
            android:id="@+id/btnAsk"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Fragen"
            android:enabled="false"/>
    </LinearLayout>

    <TextView
        android:id="@+id/tvTurnStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Verbinde …"
        android:textSize="18sp"
        android:gravity="center"
        android:paddingTop="8dp"/>

</LinearLayout>