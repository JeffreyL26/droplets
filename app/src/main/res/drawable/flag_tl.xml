<?xml version="1.0" encoding="utf-8"?>
<!--
  Flagge Philippinen (Blau/Rot mit weißem Hiss-Dreieck, goldener Sonne und drei
  Sternen) als Sprach-Icon für Tagalog. Selbst erstellte, vereinfachte Vektor-
  grafik — frei nutzbar. Sonne als 8-zackiger Stern, bewusst reduziert.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="60dp"
    android:height="40dp"
    android:viewportWidth="60"
    android:viewportHeight="40">

    <!-- Bänder: oben Blau, unten Rot (Friedenszeit) -->
    <path android:fillColor="#0038A8" android:pathData="M0,0 H60 V20 H0 Z" />
    <path android:fillColor="#CE1126" android:pathData="M0,20 H60 V40 H0 Z" />

    <!-- Weißes Hiss-Dreieck -->
    <path android:fillColor="#FFFFFF" android:pathData="M0,0 L34.64,20 L0,40 Z" />

    <!-- Goldene Sonne (8 Strahlen) -->
    <group android:translateX="11" android:translateY="20" android:scaleX="5" android:scaleY="5">
        <path android:fillColor="#FCD116"
            android:pathData="M0,-1 L0.211,-0.508 L0.707,-0.707 L0.508,-0.211 L1,0 L0.508,0.211 L0.707,0.707 L0.211,0.508 L0,1 L-0.211,0.508 L-0.707,0.707 L-0.508,0.211 L-1,0 L-0.508,-0.211 L-0.707,-0.707 L-0.211,-0.508 Z" />
    </group>

    <!-- Drei goldene Sterne an den Dreiecks-Ecken -->
    <group android:translateX="4" android:translateY="5" android:scaleX="2.2" android:scaleY="2.2">
        <path android:fillColor="#FCD116"
            android:pathData="M0,-1 L0.225,-0.309 L0.951,-0.309 L0.363,0.118 L0.588,0.809 L0,0.382 L-0.588,0.809 L-0.363,0.118 L-0.951,-0.309 L-0.225,-0.309 Z" />
    </group>
    <group android:translateX="4" android:translateY="35" android:scaleX="2.2" android:scaleY="2.2">
        <path android:fillColor="#FCD116"
            android:pathData="M0,-1 L0.225,-0.309 L0.951,-0.309 L0.363,0.118 L0.588,0.809 L0,0.382 L-0.588,0.809 L-0.363,0.118 L-0.951,-0.309 L-0.225,-0.309 Z" />
    </group>
    <group android:translateX="28" android:translateY="20" android:scaleX="2.2" android:scaleY="2.2">
        <path android:fillColor="#FCD116"
            android:pathData="M0,-1 L0.225,-0.309 L0.951,-0.309 L0.363,0.118 L0.588,0.809 L0,0.382 L-0.588,0.809 L-0.363,0.118 L-0.951,-0.309 L-0.225,-0.309 Z" />
    </group>
</vector>
