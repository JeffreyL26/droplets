<?xml version="1.0" encoding="utf-8"?>
<!--
  Flagge China (rotes Feld mit großem Stern + vier kleinen Sternen) als Sprach-
  Icon für Mandarin. Selbst erstellte, vereinfachte Vektorgrafik — frei nutzbar.
  Sterne über wiederverwendeten Einheits-Stern in <group> skaliert/rotiert.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="60dp"
    android:height="40dp"
    android:viewportWidth="60"
    android:viewportHeight="40">

    <!-- Rotes Feld -->
    <path android:fillColor="#DE2910" android:pathData="M0,0 H60 V40 H0 Z" />

    <!-- Großer Stern -->
    <group android:translateX="10" android:translateY="10" android:scaleX="5.2" android:scaleY="5.2">
        <path android:fillColor="#FFDE00"
            android:pathData="M0,-1 L0.225,-0.309 L0.951,-0.309 L0.363,0.118 L0.588,0.809 L0,0.382 L-0.588,0.809 L-0.363,0.118 L-0.951,-0.309 L-0.225,-0.309 Z" />
    </group>

    <!-- Vier kleine Sterne, zum großen Stern hin geneigt -->
    <group android:translateX="20" android:translateY="4" android:scaleX="1.8" android:scaleY="1.8" android:rotation="-121">
        <path android:fillColor="#FFDE00"
            android:pathData="M0,-1 L0.225,-0.309 L0.951,-0.309 L0.363,0.118 L0.588,0.809 L0,0.382 L-0.588,0.809 L-0.363,0.118 L-0.951,-0.309 L-0.225,-0.309 Z" />
    </group>
    <group android:translateX="24" android:translateY="8" android:scaleX="1.8" android:scaleY="1.8" android:rotation="-98">
        <path android:fillColor="#FFDE00"
            android:pathData="M0,-1 L0.225,-0.309 L0.951,-0.309 L0.363,0.118 L0.588,0.809 L0,0.382 L-0.588,0.809 L-0.363,0.118 L-0.951,-0.309 L-0.225,-0.309 Z" />
    </group>
    <group android:translateX="24" android:translateY="14" android:scaleX="1.8" android:scaleY="1.8" android:rotation="-74">
        <path android:fillColor="#FFDE00"
            android:pathData="M0,-1 L0.225,-0.309 L0.951,-0.309 L0.363,0.118 L0.588,0.809 L0,0.382 L-0.588,0.809 L-0.363,0.118 L-0.951,-0.309 L-0.225,-0.309 Z" />
    </group>
