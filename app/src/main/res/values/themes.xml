<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.GoFish" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@color/ocean_top</item>
        <item name="android:statusBarColor">@color/ocean_top</item>
        <item name="android:navigationBarColor">@color/ocean_top</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
    </style>

    <style name="Theme.GoFish.Splash" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@color/splash_bg</item>
        <item name="android:statusBarColor">@color/splash_bg</item>
        <item name="android:navigationBarColor">@color/splash_bg</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
    </style>
</resources>
